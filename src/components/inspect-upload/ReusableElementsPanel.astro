---
import Text from "@/components/fundations/elements/Text.astro";
---

<div data-panel="reusable" class="hidden rounded-xl border border-base-200 dark:border-base-800 p-4 bg-base-50 dark:bg-base-950">
  <div class="flex items-center justify-between gap-3">
    <Text tag="h3" variant="textBase" class="dark:text-white text-base-900 font-medium">Reusable Elements</Text>
    <span class="text-xs dark:text-base-500 text-base-400" data-slot="reusable-counts"></span>
  </div>
  <div class="grid grid-cols-1 xl:grid-cols-[300px_1fr] gap-4 mt-3">
    <div class="rounded-xl border border-base-200 dark:border-base-800 p-4 bg-white dark:bg-base-900">
      <div data-slot="reusable-list"></div>
    </div>
    <div class="rounded-xl border border-base-200 dark:border-base-800 p-4 bg-white dark:bg-base-900">
      <div data-slot="reusable-detail"></div>
    </div>
  </div>
</div>
