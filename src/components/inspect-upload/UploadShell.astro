---
import Text from "@/components/fundations/elements/Text.astro";

interface Props {
  statusId: string;
  inputId: string;
}

const { statusId, inputId } = Astro.props;
---

<div class="flex flex-col gap-4">
  <Text
    tag="h1"
    variant="displayXL"
    class="dark:text-white text-base-900 font-medium tracking-tighter"
  >
    Bubble upload inspector
  </Text>
  <Text tag="p" variant="textBase" class="dark:text-base-400 text-base-500 max-w-2xl">
    Upload a JSON <code>.bubble</code> export to parse pages, reusables, frontend workflows, backend workflows, and API Connector calls. Parsing runs locally in your browser.
  </Text>

  <div class="mt-2 max-w-2xl">
    <div
      data-upload-dropzone
      role="button"
      tabindex="0"
      aria-label="Upload Bubble file"
      class="group rounded-xl border border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-950 p-4 transition-colors duration-150 hover:bg-base-100 dark:hover:bg-base-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-emerald-500 cursor-pointer"
    >
      <div class="flex flex-col gap-3">
        <div class="flex flex-wrap items-center gap-2">
          <span class="inline-flex items-center rounded-md bg-base-100 dark:bg-base-900 px-2.5 py-1 text-xs font-medium dark:text-base-300 text-base-700 ring-1 ring-base-200 dark:ring-base-700">.bubble file</span>
          <span class="text-xs dark:text-base-500 text-base-400">JSON only, max 20 MB</span>
        </div>
        <div data-upload-helper class="text-sm dark:text-base-300 text-base-700">
          Drop your Bubble export here, or click to browse.
        </div>
        <input
          id={inputId}
          type="file"
          accept=".bubble,application/json"
          class="max-w-2xl rounded-lg border border-base-200 dark:border-base-800 bg-white dark:bg-base-900 px-3 py-2 text-sm dark:text-base-300 text-base-700 file:mr-3 file:rounded-md file:border-0 file:bg-base-200 file:px-3 file:py-1.5 file:text-xs file:font-medium dark:file:bg-base-800 cursor-pointer"
        />
      </div>
    </div>
    <Text id={statusId} tag="p" variant="textSM" class="dark:text-base-400 text-base-500 mt-3" aria-live="polite">
      Select a .bubble export to begin.
    </Text>
  </div>
</div>
