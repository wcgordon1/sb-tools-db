---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
// Array
const philosphy = [
{
    title: "Built To Help",
    description:
      "Useful products, clear words, and clean paths forward. The job is to make life easier, not louder.",
  },
  {
    title: "Real Partnership",
    description:
      "Best results come from working close. Ask good questions, share real opinions, and keep momentum up.",
  },
  {
    title: "Learn By Doing",
    description:
      "Do not sit around polishing slides. Build, test, adjust, and let real use dictate what comes next.",
  },
  {
    title: "Care Deeply",
    description:
      "Strong products are shaped by small choices. Care deeply about the pieces most people rush past.",
  },
  {
    title: "Stay Curious",
    description:
      "Keep an open mind, try new angles, and keep what works. No religion around tools. Just results.",
  },
  {
    title: "Good People",
    description:
      "We want to work with good people doing serious work. Mutual respect makes better products every time.",
  },
];
---

<section>
  <Wrapper variant="standard" class="py-24">
    <div
      class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-4 gap-4 overflow-hidden"
    >
      <Text
        tag="h3"
        variant="displayLG"
        data-aos="fade-up"
        data-aos-duration="1000"
        class="dark:text-white text-base-900 font-medium tracking-tighter text-balance"
        >philosphy
      </Text>
      <div
        class="flex flex-col sm:col-span-2 lg:col-span-3 divide-y divide-base-200 dark:divide-base-800 border-y border-base-200 dark:border-base-800"
      >
        {
          philosphy.map((process, index) => (
            <div class="  grid grid-cols-1 lg:grid-cols-3 py-4">
              <Text
                tag="h4"
                variant="textBase"
                data-aos="fade-up"
                data-aos-duration="1500"
                class="dark:text-white text-base-900 font-medium tracking-tight text-balance"
              >
                <span>(0{index + 1})</span>
                {process.title}
              </Text>
              <div class="lg:col-span-2 overflow-hidden">
                <Text
                  tag="h4"
                  variant="textBase"
                  data-aos="fade-up"
                  data-aos-duration="2000"
                  class="dark:text-base-400  text-base-700  "
                >
                  {process.description}
                </Text>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </Wrapper>
</section>
