---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<section class="relative overflow-hidden">
  <div
    class="absolute inset-0 pointer-events-none text-base-500 dark:text-base-500 hidden md:block"
    style="
      background-image: radial-gradient(circle, currentColor 1.5px, transparent 1.5px);
      background-size: 28px 28px;
      -webkit-mask-image: linear-gradient(to bottom right, transparent 10%, rgba(0,0,0,0.4) 45%, rgba(0,0,0,0.8) 100%);
      mask-image: linear-gradient(to bottom right, transparent 10%, rgba(0,0,0,0.4) 45%, rgba(0,0,0,0.8) 100%);
    "
  ></div>
  <Wrapper variant="standard" class="relative z-10 py-24 lg:py-48">
    <div class="overflow-hidden">
      <h1
        class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl font-bold tracking-tight dark:text-white text-base-900 mb-4"
      >
        StarterBuild
      </h1>
      <Text
        tag="p"
        variant="displayMD"
        class="dark:text-white xl:text-3xl tracking-tight font-medium text-base-900 text-balance"
      >
        we build internet businesses.
      </Text>
    </div>
  </Wrapper>
</section>
