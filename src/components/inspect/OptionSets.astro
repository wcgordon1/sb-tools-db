---
import Text from "@/components/fundations/elements/Text.astro";

interface Attribute {
  key: string;
  displayName: string;
  rawType: string;
  isList: boolean;
  baseType: string;
  dbType: string;
}

interface OptionSet {
  key: string;
  name: string;
  attributes: Attribute[];
}

interface Props {
  optionSets: {
    items: OptionSet[];
    dbml?: string;
    warnings?: string[];
  };
}

const { optionSets } = Astro.props;
const items = optionSets.items ?? [];

const withAttributes = items.filter((s) => s.attributes.length > 0);
const withoutAttributes = items.filter((s) => s.attributes.length === 0);

function getTypeColor(attr: Attribute): string {
  switch (attr.baseType) {
    case "text":
      return "text-emerald-600 dark:text-emerald-400";
    case "number":
      return "text-blue-600 dark:text-blue-400";
    case "boolean":
      return "text-purple-600 dark:text-purple-400";
    case "image":
    case "file":
      return "text-cyan-600 dark:text-cyan-400";
    default:
      if (attr.baseType.startsWith("option."))
        return "text-orange-600 dark:text-orange-400";
      return "dark:text-base-400 text-base-500";
  }
}
---

<div class="flex flex-col gap-6">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <div class="flex items-center gap-2">
        <Text
          tag="h2"
          variant="displaySM"
          class="dark:text-white text-base-900 font-medium tracking-tighter"
        >
          option sets
        </Text>
        <a href="https://manual.bubble.io/help-guides/data/static-data/option-sets" target="_blank" rel="noopener noreferrer" class="text-base-300 dark:text-base-700 hover:text-base-500 dark:hover:text-base-400 transition-colors shrink-0" title="Bubble docs: Option Sets">
          <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
          </svg>
        </a>
      </div>
      <Text tag="p" variant="textSM" class="dark:text-base-400 text-base-500 mt-1">
        {items.length} option sets &middot; {withAttributes.length} with custom attributes
      </Text>
    </div>
  </div>

  <!-- Option Sets with Attributes -->
  <div class="flex flex-col divide-y divide-base-200 dark:divide-base-800 border-y border-base-200 dark:border-base-800">
    {withAttributes.map((set, i) => (
      <details class="group" data-option-set-card>
        <summary class="flex items-center justify-between py-4 cursor-pointer select-none list-none [&::-webkit-details-marker]:hidden">
          <div class="flex items-center gap-3 min-w-0">
            <span class="text-base-400 dark:text-base-600 text-xs font-mono tabular-nums w-6 shrink-0 text-right">
              {String(i + 1).padStart(2, "0")}
            </span>
            <span class="dark:text-white text-base-900 font-medium tracking-tight text-sm truncate">
              {set.name}
            </span>
            <span class="text-base-400 dark:text-base-600 text-xs shrink-0">
              {set.attributes.length} {set.attributes.length === 1 ? "attr" : "attrs"}
            </span>
          </div>
          <svg
            class="size-4 text-base-400 dark:text-base-600 shrink-0 transition-transform duration-200 group-open:rotate-180"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
          </svg>
        </summary>

        <div class="pb-6 pl-9">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-xs text-base-400 dark:text-base-600 uppercase tracking-wider">
                  <th class="pb-2 pr-4 font-medium">Attribute</th>
                  <th class="pb-2 pr-4 font-medium">Type</th>
                  <th class="pb-2 font-medium hidden sm:table-cell">Flags</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-base-100 dark:divide-base-800/50">
                {set.attributes.map((attr) => (
                  <tr>
                    <td class="py-1.5 pr-4">
                      <span class="dark:text-base-300 text-base-700 text-sm">
                        {attr.displayName}
                      </span>
                    </td>
                    <td class="py-1.5 pr-4">
                      <span class={`text-xs font-mono ${getTypeColor(attr)}`}>
                        {attr.isList ? `list of ${attr.baseType}` : attr.baseType}
                      </span>
                    </td>
                    <td class="py-1.5 hidden sm:table-cell">
                      {attr.isList && (
                        <span class="inline-flex items-center rounded bg-blue-500/10 px-1.5 py-0.5 text-[10px] font-medium text-blue-600 dark:text-blue-400 ring-1 ring-blue-500/20">
                          list
                        </span>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </details>
    ))}
  </div>

  <!-- Option Sets without Attributes -->
  {withoutAttributes.length > 0 && (
    <div>
      <Text tag="p" variant="textXS" class="dark:text-base-500 text-base-400 uppercase tracking-wider font-medium mb-3">
        Simple option sets (no custom attributes)
      </Text>
      <div class="flex flex-wrap gap-2">
        {withoutAttributes.map((set) => (
          <span class="inline-flex items-center rounded-md bg-base-200/50 dark:bg-base-800/50 px-2.5 py-1 text-xs dark:text-base-300 text-base-600 ring-1 ring-base-200 dark:ring-base-800">
            {set.name}
          </span>
        ))}
      </div>
    </div>
  )}
</div>

<script>
  document.addEventListener("astro:page-load", () => {
    const cards = document.querySelectorAll("[data-option-set-card]");
    cards.forEach((card) => {
      card.addEventListener("toggle", () => {
        if ((card as HTMLDetailsElement).open) {
          cards.forEach((other) => {
            if (other !== card && (other as HTMLDetailsElement).open) {
              (other as HTMLDetailsElement).open = false;
            }
          });
        }
      });
    });
  });
</script>
