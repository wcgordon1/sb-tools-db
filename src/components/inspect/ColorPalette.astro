---
import Text from "@/components/fundations/elements/Text.astro";

interface ColorEntry {
  id: string;
  "%nm": string;
  "%d3": string;
  rgba: string;
}

interface Props {
  colors: {
    "%del:false"?: ColorEntry[];
    "%del:true"?: ColorEntry[];
    warnings?: string[];
  };
}

const { colors } = Astro.props;
const activeColors = colors["%del:false"] ?? [];
const deletedColors = colors["%del:true"] ?? [];

function rgbaToHex(rgba: string): string {
  const match = rgba.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/);
  if (!match) return rgba;
  const r = parseInt(match[1]).toString(16).padStart(2, "0");
  const g = parseInt(match[2]).toString(16).padStart(2, "0");
  const b = parseInt(match[3]).toString(16).padStart(2, "0");
  return `#${r}${g}${b}`;
}

function isLightColor(rgba: string): boolean {
  const match = rgba.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/);
  if (!match) return false;
  const luminance =
    (0.299 * parseInt(match[1]) +
      0.587 * parseInt(match[2]) +
      0.114 * parseInt(match[3])) /
    255;
  return luminance > 0.7;
}
---

<div class="flex flex-col gap-6">
  <div>
    <Text
      tag="h2"
      variant="displaySM"
      class="dark:text-white text-base-900 font-medium tracking-tighter"
    >
      color palette
    </Text>
    <Text tag="p" variant="textSM" class="dark:text-base-400 text-base-500 mt-1">
      {activeColors.length} active colors{deletedColors.length > 0 && ` · ${deletedColors.length} deleted`}
    </Text>
  </div>

  <!-- Active Colors Grid -->
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
    {activeColors.map((color) => {
      const hex = rgbaToHex(color.rgba);
      const light = isLightColor(color.rgba);
      return (
        <div class="flex flex-col gap-2">
          <div
            class="aspect-4/3 rounded-lg ring-1 ring-base-200 dark:ring-base-700 flex items-end p-2"
            style={`background-color: ${color.rgba};`}
          >
            <span
              class={`text-[10px] font-mono ${light ? "text-black/50" : "text-white/60"}`}
            >
              {hex}
            </span>
          </div>
          <div class="flex flex-col">
            <span class="text-xs font-medium dark:text-base-300 text-base-700 truncate">
              {color["%nm"]}
            </span>
            <span class="text-[10px] dark:text-base-500 text-base-400 truncate">
              {color["%d3"]}
            </span>
          </div>
        </div>
      );
    })}
  </div>

  <!-- Deleted Colors -->
  {deletedColors.length > 0 && (
    <div>
      <Text tag="p" variant="textXS" class="dark:text-base-500 text-base-400 uppercase tracking-wider font-medium mb-3">
        Deleted colors
      </Text>
      <div class="flex flex-wrap gap-3">
        {deletedColors.map((color) => {
          const hex = rgbaToHex(color.rgba);
          return (
            <div class="flex items-center gap-2 opacity-50">
              <span
                class="size-5 rounded ring-1 ring-base-200 dark:ring-base-700"
                style={`background-color: ${color.rgba};`}
              />
              <span class="text-xs dark:text-base-400 text-base-500 line-through">
                {color["%nm"]}
              </span>
              <span class="text-[10px] font-mono dark:text-base-600 text-base-400">
                {hex}
              </span>
            </div>
          );
        })}
      </div>
    </div>
  )}
</div>
