---
import Text from "@/components/fundations/elements/Text.astro";

interface ColorEntry {
  id: string;
  "%nm": string;
  "%d3": string;
  rgba: string;
}

interface Props {
  colors: {
    "%del:false"?: ColorEntry[];
    "%del:true"?: ColorEntry[];
    warnings?: string[];
  };
}

const { colors } = Astro.props;
const activeColors = colors["%del:false"] ?? [];
const deletedColors = colors["%del:true"] ?? [];

function rgbaToHex(rgba: string): string {
  const match = rgba.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/);
  if (!match) return rgba;
  const r = parseInt(match[1]).toString(16).padStart(2, "0");
  const g = parseInt(match[2]).toString(16).padStart(2, "0");
  const b = parseInt(match[3]).toString(16).padStart(2, "0");
  return `#${r}${g}${b}`;
}

function isLightColor(rgba: string): boolean {
  const match = rgba.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)/);
  if (!match) return false;
  const luminance =
    (0.299 * parseInt(match[1]) +
      0.587 * parseInt(match[2]) +
      0.114 * parseInt(match[3])) /
    255;
  return luminance > 0.7;
}
---

<div class="flex flex-col gap-6">
  <div>
    <div class="flex items-center gap-2">
      <Text
        tag="h2"
        variant="displaySM"
        class="dark:text-white text-base-900 font-medium tracking-tighter"
      >
        color palette
      </Text>
      <a href="https://manual.bubble.io/help-guides/design/styling/color-variables" target="_blank" rel="noopener noreferrer" class="text-base-300 dark:text-base-700 hover:text-base-500 dark:hover:text-base-400 transition-colors shrink-0" title="Bubble docs: Color Variables">
        <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>
    </div>
    <Text tag="p" variant="textSM" class="dark:text-base-400 text-base-500 mt-1">
      {activeColors.length} active colors{deletedColors.length > 0 && ` · ${deletedColors.length} deleted`}
    </Text>
  </div>

  <!-- Active Colors Grid -->
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3">
    {activeColors.map((color) => {
      const hex = rgbaToHex(color.rgba);
      const light = isLightColor(color.rgba);
      return (
        <div class="flex flex-col gap-2">
          <div
            data-color-swatch
            data-hex={hex}
            class="group/swatch relative aspect-4/3 rounded-lg ring-1 ring-base-200 dark:ring-base-700 flex items-end p-2 cursor-pointer transition-shadow hover:ring-2"
            style={`background-color: ${color.rgba};`}
          >
            <span
              class={`text-[10px] font-mono ${light ? "text-black/50" : "text-white/60"}`}
            >
              {hex}
            </span>
            <span
              data-copy-label
              class={`absolute bottom-2 right-2 text-[10px] font-medium opacity-0 group-hover/swatch:opacity-100 transition-opacity duration-150 ${light ? "text-black/70" : "text-white/70"}`}
            >
              Copy
            </span>
          </div>
          <div class="flex flex-col">
            <span class="text-xs font-medium dark:text-base-300 text-base-700 truncate">
              {color["%nm"]}
            </span>
            <span class="text-[10px] dark:text-base-500 text-base-400 truncate">
              {color["%d3"]}
            </span>
          </div>
        </div>
      );
    })}
  </div>

  <!-- Deleted Colors -->
  {deletedColors.length > 0 && (
    <div>
      <Text tag="p" variant="textXS" class="dark:text-base-500 text-base-400 uppercase tracking-wider font-medium mb-3">
        Deleted colors
      </Text>
      <div class="flex flex-wrap gap-3">
        {deletedColors.map((color) => {
          const hex = rgbaToHex(color.rgba);
          return (
            <div class="flex items-center gap-2 opacity-50">
              <span
                class="size-5 rounded ring-1 ring-base-200 dark:ring-base-700"
                style={`background-color: ${color.rgba};`}
              />
              <span class="text-xs dark:text-base-400 text-base-500 line-through">
                {color["%nm"]}
              </span>
              <span class="text-[10px] font-mono dark:text-base-600 text-base-400">
                {hex}
              </span>
            </div>
          );
        })}
      </div>
    </div>
  )}
</div>

<script>
  function initColorCopy() {
    const swatches = document.querySelectorAll("[data-color-swatch]");
    if (!swatches.length) return;

    swatches.forEach((swatch) => {
      if (swatch.hasAttribute("data-copy-init")) return;
      swatch.setAttribute("data-copy-init", "true");

      swatch.addEventListener("click", async () => {
        const hex = swatch.getAttribute("data-hex");
        const label = swatch.querySelector("[data-copy-label]");
        if (!hex || !label) return;

        try {
          await navigator.clipboard.writeText(hex);
        } catch {
          const textarea = document.createElement("textarea");
          textarea.value = hex;
          textarea.style.position = "fixed";
          textarea.style.opacity = "0";
          document.body.appendChild(textarea);
          textarea.select();
          document.execCommand("copy");
          document.body.removeChild(textarea);
        }

        label.textContent = "Copied";
        label.style.opacity = "1";
        setTimeout(() => {
          label.textContent = "Copy";
          label.style.opacity = "";
        }, 1500);
      });
    });
  }

  document.addEventListener("DOMContentLoaded", initColorCopy);
  document.addEventListener("astro:page-load", initColorCopy);
</script>
