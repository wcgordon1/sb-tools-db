---
import Text from "@/components/fundations/elements/Text.astro";
import { getOverviewBadge } from "@/lib/inspect/overview-score";

interface Props {
  typesCount: number;
  fieldsCount: number;
  refsCount: number;
  pagesCount: number;
  optionSetsCount: number;
  colorsCount: number;
}

const { typesCount, fieldsCount, refsCount, pagesCount, optionSetsCount, colorsCount } = Astro.props;

const badge = getOverviewBadge({
  typesCount,
  fieldsCount,
  refsCount,
  pagesCount,
  optionSetsCount,
  colorsCount,
});

const stats = [
  { label: "Data Types", value: typesCount },
  { label: "Fields", value: fieldsCount },
  { label: "Relationships", value: refsCount },
  { label: "Pages", value: pagesCount },
  { label: "Option Sets", value: optionSetsCount },
  { label: "Colors", value: colorsCount },
];
---

<div class="flex flex-col gap-6">
  <div>
    <div class="flex items-center gap-3">
      <Text
        tag="h2"
        variant="displaySM"
        class="dark:text-white text-base-900 font-medium tracking-tighter"
      >
        app overview
      </Text>
      <span class="inline-flex items-center rounded-full bg-blue-100 dark:bg-blue-500/15 px-4 py-1.5 text-sm font-semibold text-blue-600 dark:text-blue-300 ring-1 ring-blue-200 dark:ring-blue-500/30">
        {badge.tier}
      </span>
    </div>
    <Text tag="p" variant="textSM" class="dark:text-base-400 text-base-500 mt-2">
      {badge.description}
    </Text>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
    {stats.map((stat) => (
      <div class="rounded-lg border border-base-200 dark:border-base-800 p-4">
        <Text tag="span" variant="textXS" class="dark:text-base-500 text-base-400 uppercase tracking-wider font-medium">
          {stat.label}
        </Text>
        <p class="text-2xl font-semibold dark:text-white text-base-900 mt-1 tabular-nums tracking-tight">
          {stat.value}
        </p>
      </div>
    ))}
  </div>

</div>
