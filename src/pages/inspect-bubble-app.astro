---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import BubbleDetection from "@/components/inspect/BubbleDetection.astro";
import DatabaseSchema from "@/components/inspect/DatabaseSchema.astro";
import OptionSets from "@/components/inspect/OptionSets.astro";
import ColorPalette from "@/components/inspect/ColorPalette.astro";
import PageList from "@/components/inspect/PageList.astro";
import ApiRoutes from "@/components/inspect/ApiRoutes.astro";
import ConsoleMessages from "@/components/inspect/ConsoleMessages.astro";
import AppOverview from "@/components/inspect/AppOverview.astro";
import { inspectUrl } from "@/lib/worker/client";
import { deriveCallerId } from "@/lib/worker/caller-id";
import { saveInspectionResult } from "@/lib/worker/storage";
import type { InspectError } from "@/lib/worker/types";

export const prerender = false;

const MAX_TRIES = 5;

const rawUrl = Astro.url.searchParams.get("url") ?? "";
const requestCookies = Astro.request.headers.get("cookie") ?? "";
const hasInspectTrigger = requestCookies.includes("inspect-trigger=1");
let inspectionData: any = null;
let inspectionError: string | null = null;
let notBubble = false;

if (rawUrl && hasInspectTrigger) {
  try {
    const callerId = deriveCallerId(Astro.request);
    const result = await inspectUrl(rawUrl, callerId);

    if (result.ok) {
      inspectionData = result.data;
      await saveInspectionResult(result.data);

      if (!result.data.bubbleDetection?.isLikelyBubble) {
        notBubble = true;
        inspectionData = null;
      }
    }

    if (!result.ok) {
      inspectionError = (result as InspectError).error;
    }
  } catch (err) {
    inspectionError =
      err instanceof Error ? err.message : "Something went wrong";
  }
}

const hasResults = inspectionData !== null;

const detection = inspectionData?.bubbleDetection;
const summary = inspectionData?.summary;
const database = inspectionData?.database;
const optionSets = inspectionData?.optionSets;
const colors = inspectionData?.colors;
const pages = inspectionData?.pages;
const debugMeta = inspectionData?.debugMeta;
const consoleMessages = inspectionData?.consoleMessages ?? [];
const totalFields = database?.types?.reduce((sum: number, t: any) => sum + t.fields.length, 0) ?? 0;
const activeColorsCount = colors?.["%del:false"]?.length ?? 0;
---

<BaseLayout
  pageTitle="Inspect Bubble App"
  pageDescription="Analyze the structure of a Bubble.io application"
>
  <!-- Header + Form -->
  <section>
    <Wrapper variant="standard" class="pt-32 pb-12">
      <div class="flex flex-col gap-4">
        <Text
          tag="h1"
          variant="displayXL"
          class="dark:text-white text-base-900 font-medium tracking-tighter"
        >
          Bubble app inspector
        </Text>
        {!hasResults && (
          <Text tag="p" variant="textBase" class="dark:text-base-400 text-base-500 max-w-xl">
            Enter any Bubble.io app URL to reverse-engineer its database schema, option sets, pages, color palette, and more.
          </Text>
        )}

        <!-- Form -->
        <div class="flex flex-col gap-3 mt-2" data-inspect-form>
          <div class="relative max-w-md w-full">
            <div class="group/bar flex items-center rounded-lg border border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-900 transition-colors focus-within:border-base-400 dark:focus-within:border-base-600">
              <div class="pointer-events-none flex items-center pl-3">
                <svg class="size-3.5 dark:text-base-600 text-base-400 transition-colors group-focus-within/bar:text-base-900 dark:group-focus-within/bar:text-white" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
                </svg>
              </div>
              <input
                type="text"
                data-url-input
                value={rawUrl}
                placeholder="app.example.com"
                class="flex-1 bg-transparent border-0 pl-2 pr-2 py-2.5 text-sm dark:text-white text-base-900 placeholder:text-base-400 dark:placeholder:text-base-600 focus:outline-none focus:ring-0 outline-none"
                style="outline: none; box-shadow: none;"
              />
              <div class="border-l border-base-200 dark:border-base-800 h-5 mx-0.5" />
              <button
                data-submit-btn
                class="group inline-flex items-center gap-1.5 px-3 py-2.5 text-sm font-medium dark:text-base-400 text-base-500 hover:dark:text-white hover:text-base-900 transition-colors cursor-pointer disabled:opacity-40 disabled:cursor-not-allowed shrink-0 rounded-r-lg"
              >
                <svg data-btn-icon class="size-3.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                </svg>
                <span data-btn-text>Inspect</span>
                <svg data-btn-spinner class="hidden size-3.5 animate-spin" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" />
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z" />
                </svg>
              </button>
            </div>
          </div>
          <div class="flex items-center justify-between mt-1 max-w-md">
            <span data-tries-text class="text-xs dark:text-base-600 text-base-400"></span>
            <span
              data-url-error
              class="text-xs text-rose-500 opacity-0 transition-opacity duration-200"
            >
              Not a valid URL
            </span>
            {inspectionError && (
              <span class="text-xs text-rose-500">{inspectionError}</span>
            )}
          </div>
        </div>

        <!-- Result header badge row -->
        {hasResults && (
          <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center sm:gap-3 mt-2">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-500/10 px-2.5 py-0.5 text-xs font-medium text-emerald-600 dark:text-emerald-400 ring-1 ring-emerald-500/20 w-fit">
              <span class="size-1.5 rounded-full bg-emerald-500"></span>
              Bubble Detected
            </span>
            <Text
              tag="span"
              variant="textSM"
              class="dark:text-base-400 text-base-500 break-all"
            >
              {inspectionData.finalUrl}
            </Text>
            <Text
              tag="span"
              variant="textXS"
              class="dark:text-base-500 text-base-400 whitespace-nowrap"
            >
              v{detection.bubble_version} &middot; {detection.app_id}
            </Text>
          </div>
        )}

        <!-- Not bubble notice -->
        {notBubble && (
          <div class="flex items-start gap-2 rounded-lg border border-amber-500/20 bg-amber-500/5 p-4">
            <span class="text-amber-500 text-sm mt-0.5 shrink-0">!</span>
            <div>
              <Text tag="p" variant="textSM" class="text-amber-700 dark:text-amber-400 font-medium">
                Not a Bubble app
              </Text>
              <Text tag="p" variant="textXS" class="text-amber-600/80 dark:text-amber-500/80 mt-0.5">
                {rawUrl} doesn't appear to be built with Bubble.io
              </Text>
            </div>
          </div>
        )}
      </div>
    </Wrapper>
  </section>

  <!-- Loading skeleton (shown client-side while navigating to SSR) -->
  <div data-loading-skeleton class="hidden">
    <section>
      <Wrapper variant="standard" class="pb-24">
        <div class="rounded-2xl border border-base-200 dark:border-base-800 bg-base-50 dark:bg-base-950 p-8 sm:p-12">
          <div class="flex flex-col items-center justify-center gap-6 min-h-80">
            <!-- Animated scanner -->
            <div class="relative size-16">
              <div class="absolute inset-0 rounded-full border-2 border-base-200 dark:border-base-800"></div>
              <div class="absolute inset-0 rounded-full border-2 border-transparent border-t-base-900 dark:border-t-white animate-spin"></div>
              <div class="absolute inset-2 rounded-full border-2 border-transparent border-b-base-400 dark:border-b-base-600 animate-spin" style="animation-direction:reverse;animation-duration:1.5s"></div>
              <div class="absolute inset-4 rounded-full bg-base-200 dark:bg-base-800 flex items-center justify-center">
                <svg class="size-4 dark:text-base-500 text-base-400" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                </svg>
              </div>
            </div>

            <div class="flex flex-col items-center gap-2 text-center">
              <Text tag="p" variant="textBase" class="dark:text-white text-base-900 font-medium">
                Inspecting application...
              </Text>
              <Text tag="p" variant="textSM" class="dark:text-base-500 text-base-400 max-w-sm">
                Scanning runtime, database schema, option sets, pages, api routes, and more... This usually takes 10–20 seconds.
              </Text>
            </div>

            <!-- Animated progress dots -->
            <div class="flex items-center gap-3 mt-2">
              <div class="flex items-center gap-1.5">
                <span class="size-1.5 rounded-full bg-base-900 dark:bg-white animate-pulse"></span>
                <span class="size-1.5 rounded-full bg-base-900 dark:bg-white animate-pulse" style="animation-delay:0.2s"></span>
                <span class="size-1.5 rounded-full bg-base-900 dark:bg-white animate-pulse" style="animation-delay:0.4s"></span>
              </div>
            </div>

            <!-- Fake progress steps -->
            <div class="flex flex-wrap justify-center gap-2 mt-4">
              <span class="inline-flex items-center gap-1.5 rounded-full bg-base-200/50 dark:bg-base-800/50 px-2.5 py-1 text-[10px] dark:text-base-500 text-base-400 ring-1 ring-base-200 dark:ring-base-800 animate-pulse">
                Detecting runtime
              </span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-base-200/50 dark:bg-base-800/50 px-2.5 py-1 text-[10px] dark:text-base-500 text-base-400 ring-1 ring-base-200 dark:ring-base-800 animate-pulse" style="animation-delay:0.3s">
                Extracting schema
              </span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-base-200/50 dark:bg-base-800/50 px-2.5 py-1 text-[10px] dark:text-base-500 text-base-400 ring-1 ring-base-200 dark:ring-base-800 animate-pulse" style="animation-delay:0.6s">
                Parsing option sets
              </span>
              <span class="inline-flex items-center gap-1.5 rounded-full bg-base-200/50 dark:bg-base-800/50 px-2.5 py-1 text-[10px] dark:text-base-500 text-base-400 ring-1 ring-base-200 dark:ring-base-800 animate-pulse" style="animation-delay:0.9s">
                Mapping pages
              </span>
            </div>
          </div>
        </div>
      </Wrapper>
    </section>
  </div>

  <!-- Empty state: what this tool does -->
  {!hasResults && !notBubble && !inspectionError && (
    <>
      <section>
        <Wrapper variant="standard" class="pb-16">
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div class="rounded-xl border border-base-200 dark:border-base-800 p-6 flex flex-col gap-3">
              <div class="size-9 rounded-lg bg-base-200/50 dark:bg-base-800/50 flex items-center justify-center">
                <svg class="size-4.5 dark:text-base-400 text-base-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" />
                </svg>
              </div>
              <Text tag="h3" variant="textBase" class="dark:text-white text-base-900 font-medium">
                Database schema
              </Text>
              <Text tag="p" variant="textSM" class="dark:text-base-400 text-base-500">
                Discover every data type, field, and relationship in the app's database.
              </Text>
            </div>

            <div class="rounded-xl border border-base-200 dark:border-base-800 p-6 flex flex-col gap-3">
              <div class="size-9 rounded-lg bg-base-200/50 dark:bg-base-800/50 flex items-center justify-center">
                <svg class="size-4.5 dark:text-base-400 text-base-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
                </svg>
              </div>
              <Text tag="h3" variant="textBase" class="dark:text-white text-base-900 font-medium">
                Option sets
              </Text>
              <Text tag="p" variant="textSM" class="dark:text-base-400 text-base-500">
                See all static option sets with their attributes and data type. 
              </Text>
            </div>

            <div class="rounded-xl border border-base-200 dark:border-base-800 p-6 flex flex-col gap-3">
              <div class="size-9 rounded-lg bg-base-200/50 dark:bg-base-800/50 flex items-center justify-center">
                <svg class="size-4.5 dark:text-base-400 text-base-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                </svg>
              </div>
              <Text tag="h3" variant="textBase" class="dark:text-white text-base-900 font-medium">
                Pages
              </Text>
              <Text tag="p" variant="textSM" class="dark:text-base-400 text-base-500">
                Every page the app exposes, categorized by type and purpose.
              </Text>
            </div>

            <div class="rounded-xl border border-base-200 dark:border-base-800 p-6 flex flex-col gap-3">
              <div class="size-9 rounded-lg bg-base-200/50 dark:bg-base-800/50 flex items-center justify-center">
                <svg class="size-4.5 dark:text-base-400 text-base-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.098 19.902a3.75 3.75 0 005.304 0l6.401-6.402M6.75 21A3.75 3.75 0 013 17.25V4.125C3 3.504 3.504 3 4.125 3h5.25c.621 0 1.125.504 1.125 1.125v4.072M6.75 21a3.75 3.75 0 003.75-3.75V8.197M6.75 21h13.125c.621 0 1.125-.504 1.125-1.125v-5.25c0-.621-.504-1.125-1.125-1.125h-4.072M10.5 8.197l2.88-2.88c.438-.439 1.15-.439 1.59 0l3.712 3.713c.44.44.44 1.152 0 1.59l-2.879 2.88M6.75 17.25h.008v.008H6.75v-.008z" />
                </svg>
              </div>
              <Text tag="h3" variant="textBase" class="dark:text-white text-base-900 font-medium">
                Color palette
              </Text>
              <Text tag="p" variant="textSM" class="dark:text-base-400 text-base-500">
                Extract the complete color palette with hex values and names.
              </Text>
            </div>

            <div class="rounded-xl border border-base-200 dark:border-base-800 p-6 flex flex-col gap-3">
              <div class="size-9 rounded-lg bg-base-200/50 dark:bg-base-800/50 flex items-center justify-center">
                <svg class="size-4.5 dark:text-base-400 text-base-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
                </svg>
              </div>
              <Text tag="h3" variant="textBase" class="dark:text-white text-base-900 font-medium">
                API endpoints
              </Text>
              <Text tag="p" variant="textSM" class="dark:text-base-400 text-base-500">
                Map out the data & workflow API routes your app exposes. 
              </Text>
            </div>

            <div class="rounded-xl border border-base-200 dark:border-base-800 p-6 flex flex-col gap-3">
              <div class="size-9 rounded-lg bg-base-200/50 dark:bg-base-800/50 flex items-center justify-center">
                <svg class="size-4.5 dark:text-base-400 text-base-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" />
                </svg>
              </div>
              <Text tag="h3" variant="textBase" class="dark:text-white text-base-900 font-medium">
                Console output
              </Text>
              <Text tag="p" variant="textSM" class="dark:text-base-400 text-base-500">
                Capture console errors, warnings, and logs, grouped and color-coded by severity.
              </Text>
            </div>
          </div>
        </Wrapper>
      </section>

      <section>
        <Wrapper variant="standard" class="pb-24">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-12">
            <div class="flex flex-col gap-3">
              <Text tag="h2" variant="displaySM" class="dark:text-white text-base-900 font-medium tracking-tighter">
                Understand any Bubble app in seconds
              </Text>
              <Text tag="p" variant="textSM" class="dark:text-base-400 text-base-500">
                Paste a URL and get a complete breakdown of the application's architecture: data model, pages, option sets, colors, api routes, and console output. No login required, no access to the app needed. Everything is extracted from the public runtime.
              </Text>
            </div>
            <div class="flex flex-col gap-3">
              <Text tag="h2" variant="displaySM" class="dark:text-white text-base-900 font-medium tracking-tighter">
                Built for Bubble developers
              </Text>
              <Text tag="p" variant="textSM" class="dark:text-base-400 text-base-500">
                Whether you're auditing your own app, onboarding to a new project, or reverse-engineering a competitor, the inspector gives you the visibility that Bubble's editor doesn't. Export schemas as DBML, download ERD diagrams, and explore relationships interactively.
              </Text>
            </div>
          </div>
        </Wrapper>
      </section>
    </>
  )}

  <!-- Results -->
  {hasResults && (
    <>
      <!-- Detection Summary -->
      <section>
        <Wrapper variant="standard" class="pb-16">
          <BubbleDetection
            detection={detection}
            summary={summary}
            debugMeta={debugMeta}
            submittedUrl={inspectionData.submittedUrl}
            finalUrl={inspectionData.finalUrl}
          />
        </Wrapper>
      </section>

      <!-- App Overview -->
      <section>
        <Wrapper variant="standard" class="pb-16">
          <AppOverview
            typesCount={database.types.length}
            fieldsCount={totalFields}
            refsCount={database.refs.length}
            pagesCount={pages.items.length}
            optionSetsCount={optionSets.items?.length ?? 0}
            colorsCount={activeColorsCount}
          />
        </Wrapper>
      </section>

      <!-- Pages -->
      <section>
        <Wrapper variant="standard" class="pb-16">
          <PageList pages={pages} baseUrl={inspectionData.finalUrl} />
        </Wrapper>
      </section>

      <!-- Color Palette -->
      <section>
        <Wrapper variant="standard" class="pb-16">
          <ColorPalette colors={colors} />
        </Wrapper>
      </section>

      <!-- Database Schema -->
      <section>
        <Wrapper variant="standard" class="pb-16">
          <DatabaseSchema database={database} appName={detection.app_id ?? inspectionData.finalUrl} />
        </Wrapper>
      </section>

      <!-- Option Sets -->
      <section>
        <Wrapper variant="standard" class="pb-16">
          <OptionSets optionSets={optionSets} />
        </Wrapper>
      </section>

      <!-- API Routes (blurred) -->
      <section>
        <Wrapper variant="standard" class="pb-16">
          <ApiRoutes types={database.types} baseUrl={inspectionData.finalUrl} />
        </Wrapper>
      </section>

      <!-- Console Messages -->
      <section>
        <Wrapper variant="standard" class="pb-24">
          <ConsoleMessages messages={consoleMessages} />
        </Wrapper>
      </section>
    </>
  )}
</BaseLayout>

<script define:vars={{ MAX_TRIES }}>
  function initInspectForm() {
    const form = document.querySelector("[data-inspect-form]");
    if (!form || form.hasAttribute("data-initialized")) return;
    form.setAttribute("data-initialized", "true");

    const input = form.querySelector("[data-url-input]");
    const submitBtn = form.querySelector("[data-submit-btn]");
    const btnText = form.querySelector("[data-btn-text]");
    const btnIcon = form.querySelector("[data-btn-icon]");
    const btnSpinner = form.querySelector("[data-btn-spinner]");
    const urlError = form.querySelector("[data-url-error]");
    const triesText = form.querySelector("[data-tries-text]");
    const loadingSkeleton = document.querySelector("[data-loading-skeleton]");

    var STORAGE_KEY = "inspect-bubble-tries";

    function getTriesUsed() {
      try {
        var stored = JSON.parse(localStorage.getItem(STORAGE_KEY) || "{}");
        if (stored.resetAt && Date.now() > stored.resetAt) {
          localStorage.removeItem(STORAGE_KEY);
          return 0;
        }
        return stored.count || 0;
      } catch {
        return 0;
      }
    }

    function incrementTries() {
      var newCount = getTriesUsed() + 1;
      var resetAt = Date.now() + 24 * 60 * 60 * 1000;
      localStorage.setItem(STORAGE_KEY, JSON.stringify({ count: newCount, resetAt: resetAt }));
      return newCount;
    }

    function updateTriesDisplay() {
      var remaining = MAX_TRIES - getTriesUsed();
      if (triesText) {
        triesText.textContent = remaining <= 0
          ? "No inspections remaining (resets in 24h)"
          : remaining + " of " + MAX_TRIES + " inspections remaining";
      }
      if (remaining <= 0 && submitBtn) submitBtn.disabled = true;
    }

    function normalizeUrl(raw) {
      var url = raw.trim();
      if (!url) return null;
      if (!/^https?:\/\//i.test(url)) url = "https://" + url;
      try {
        var parsed = new URL(url);
        if (parsed.protocol !== "http:" && parsed.protocol !== "https:") return null;
        if (!parsed.hostname.includes(".")) return null;
        return parsed.href;
      } catch {
        return null;
      }
    }

    function flashError(el, msg, ms) {
      if (!el) return;
      if (msg) el.textContent = msg;
      el.style.opacity = "1";
      setTimeout(function() { el.style.opacity = "0"; }, ms || 2000);
    }

    function setLoading(loading) {
      if (submitBtn) submitBtn.disabled = loading;
      if (btnText) btnText.textContent = loading ? "Inspecting…" : "Inspect";
      if (btnIcon) btnIcon.classList.toggle("hidden", loading);
      if (btnSpinner) btnSpinner.classList.toggle("hidden", !loading);
      if (input) input.disabled = loading;
      if (loadingSkeleton) loadingSkeleton.classList.toggle("hidden", !loading);
    }

    function handleSubmit() {
      if (getTriesUsed() >= MAX_TRIES) {
        flashError(urlError, "No inspections remaining", 3000);
        return;
      }

      var raw = input ? input.value : "";
      var url = normalizeUrl(raw);

      if (!url) {
        flashError(urlError, "Not a valid URL", 2000);
        return;
      }

      incrementTries();
      updateTriesDisplay();
      setLoading(true);

      document.cookie = "inspect-trigger=1; path=/; max-age=120; SameSite=Lax";
      window.location.href = "/inspect-bubble-app?url=" + encodeURIComponent(url);
    }

    if (input) {
      input.addEventListener("keydown", function(e) {
        if (e.key === "Enter") {
          e.preventDefault();
          handleSubmit();
        }
      });
    }

    if (submitBtn) submitBtn.addEventListener("click", handleSubmit);

    updateTriesDisplay();
  }

  document.addEventListener("DOMContentLoaded", initInspectForm);
  document.addEventListener("astro:page-load", initInspectForm);
</script>
