---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
---

<BaseLayout>
  <section class="relative overflow-hidden">
    <div
      id="about-dots"
      class="absolute inset-0 pointer-events-none text-base-500 dark:text-base-500 transition-opacity duration-500 opacity-50"
      style="
        background-image: radial-gradient(circle, currentColor 1.5px, transparent 1.5px);
        background-size: 28px 28px;
        -webkit-mask-image: linear-gradient(to bottom right, transparent 10%, rgba(0,0,0,0.25) 50%, rgba(0,0,0,1) 100%);
        mask-image: linear-gradient(to bottom right, transparent 10%, rgba(0,0,0,0.25) 50%, rgba(0,0,0,1) 100%);
      "
    ></div>
    <Wrapper variant="standard" class="relative z-10 py-24 lg:pt-48 lg:pb-32">
      <h1
        class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight dark:text-white text-black"
      >
        About
      </h1>
      <div class="flex items-center gap-1 mt-4 mb-10">
        <button
          type="button"
          data-target="small"
          class="size-toggle p-2 rounded-lg transition-colors duration-200 text-base-400 dark:text-base-600 hover:text-base-600 dark:hover:text-base-400 cursor-pointer"
          aria-label="Short version"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="9" width="14" height="2" rx="1" fill="currentColor" />
          </svg>
        </button>
        <button
          type="button"
          data-target="medium"
          class="size-toggle active p-2 rounded-lg transition-colors duration-200 text-base-900 dark:text-white cursor-pointer"
          aria-label="Medium version"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="7" width="14" height="2" rx="1" fill="currentColor" />
            <rect x="3" y="11" width="14" height="2" rx="1" fill="currentColor" />
          </svg>
        </button>
        <button
          type="button"
          data-target="large"
          class="size-toggle p-2 rounded-lg transition-colors duration-200 text-base-400 dark:text-base-600 hover:text-base-600 dark:hover:text-base-400 cursor-pointer"
          aria-label="Full version"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="3" y="5" width="14" height="2" rx="1" fill="currentColor" />
            <rect x="3" y="9" width="14" height="2" rx="1" fill="currentColor" />
            <rect x="3" y="13" width="14" height="2" rx="1" fill="currentColor" />
          </svg>
        </button>
      </div>

      <!-- SMALL: The essentials. Edit this text freely. -->
      <div class="about-text" data-size="small">
        <div>
          <Text
            tag="p"
            variant="textXL"
            class="text-base-500 dark:text-base-300 md:max-w-2xl"
          >
            We build internet businesses.
          </Text>
        </div>
      </div>

      <!-- MEDIUM: Hemingway style. Edit this text freely. -->
      <div class="about-text active" data-size="medium">
        <div>
          <Text
            tag="p"
            variant="textXL"
            class="text-base-500 dark:text-base-300 md:max-w-2xl"
          >
            We build internet businesses. Good tools should be simple. They should work without
            thinking.
          </Text>
          <Text
            tag="p"
            variant="textXL"
            class="text-base-500 dark:text-base-300 md:max-w-2xl mt-6"
          >
            We design and build products for use. No excess. No
            noise. Just purposeful software.
          </Text>
        </div>
      </div>

      <!-- LARGE: Full website copy. Edit this text freely. -->
      <div class="about-text" data-size="large">
        <div>
          <Text
            tag="p"
            variant="textXL"
            class="text-base-500 dark:text-base-300 md:max-w-2xl"
          >
            We build internet businesses. StarterBuild was founded on a simple
            observation: most software tries to do too much. The best tools
            disappear into the workflow. They solve one problem well and get out
            of the way. That's what we aim to create.
          </Text>
          <Text
            tag="p"
            variant="textXL"
            class="text-base-500 dark:text-base-300 md:max-w-2xl mt-6"
          >
            Our process is deliberately minimal. We start with the problem, not
            the technology. We talk to the people who will use what we build. We
            strip away everything that doesn't serve the core experience. Then we
            design and engineer software that feels inevitable... like it couldn't
            have been built any other way.
          </Text>
          <Text
            tag="p"
            variant="textXL"
            class="text-base-500 dark:text-base-300 md:max-w-2xl mt-6"
          >
            We work from Newport Beach, California. Our team is small by choice.
            Every person here ships product. We don't have layers of management
            or endless review cycles. We have strong opinions, loose processes,
            and a shared belief that great software is built by small teams who
            care deeply about craft.
          </Text>
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>

<style>
  .about-text {
    display: grid;
    grid-template-rows: 0fr;
    opacity: 0;
    transition:
      grid-template-rows 400ms ease,
      opacity 300ms ease;
  }

  .about-text.active {
    grid-template-rows: 1fr;
    opacity: 1;
  }

  .about-text > div {
    overflow: hidden;
  }
</style>

<script type="module">
  const buttons = document.querySelectorAll(".size-toggle");
  const blocks = document.querySelectorAll(".about-text");
  const dots = document.getElementById("about-dots");

  const activeClasses = ["text-base-900", "dark:text-white"];
  const inactiveClasses = [
    "text-base-400",
    "dark:text-base-600",
    "hover:text-base-600",
    "dark:hover:text-base-400",
  ];

  const dotOpacity = { small: "opacity-0", medium: "opacity-25", large: "opacity-50" };

  function setSize(target) {
    blocks.forEach((block) => {
      block.classList.toggle("active", block.dataset.size === target);
    });

    buttons.forEach((b) => {
      const isActive = b.dataset.target === target;
      b.classList.toggle("active", isActive);
      activeClasses.forEach((c) => b.classList.toggle(c, isActive));
      inactiveClasses.forEach((c) => b.classList.toggle(c, !isActive));
    });

    Object.values(dotOpacity).forEach((c) => dots.classList.remove(c));
    dots.classList.add(dotOpacity[target]);
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => setSize(btn.dataset.target));
  });
</script>
